// ============================================================
// Linguara — To'liq ma'lumotlar bazasi sxemasi (DBML)
// Versiya: 2.1 (to'ldirilmoqda — enum + delete qoidalari)
// ============================================================

// ─── ENUM TIPLARI (manba: src/common/utils/enum.ts) ──────────
// Bo'limlar to'ldirilgan sari bu ro'yxat o'sib boradi.
Enum language {
  en
  uz
}
Enum part_of_speech {
  noun
  verb
  adjective
  adverb
  phrase
}
Enum word_relation_type {
  synonym
  antonym
}
Enum question_type {
  multiple_choice
  fill_in_blank
  true_false
  matching
}
Enum exercise_type {
  matching
  fill_in_blank
  multiple_choice
}
Enum vocab_status {
  new
  learning
  mastered
}
Enum cefr_level {
  A1
  A2
  B1
  B2
  C1
  C2
}
Enum practice_mode {
  flashcard
  multiple_choice
  typing
  audio
}
Enum group_status {
  active
  inactive
  archived
}
Enum session_status {
  scheduled
  ongoing
  completed
  cancelled
}
Enum attendance_status {
  present
  absent
  late
  excused
}
Enum league {
  bronze
  silver
  gold
  platinum
  diamond
}
Enum xp_source {
  lesson_complete
  vocabulary_mastered
  streak_bonus
  challenge_bonus
  assignment_bonus
}
Enum achievement_condition {
  streak
  lessons
  vocabulary
  score
  attendance
}
Enum activity_type {
  lesson
  vocabulary
  listening
  reading
  test
}
Enum assignment_type {
  reading
  listening
  writing
  speaking
  grammar
  vocabulary
  test
}
Enum assignment_status {
  draft
  active
  closed
}
Enum submission_status {
  pending
  submitted
  graded
  late
  revision_needed
}
Enum notification_type {
  message
  lesson_unlocked
  achievement
  assignment
  reminder
  system
}
Enum role {
  superAdmin
  admin
  teacher
  subTeacher
  student
}
Enum lesson_status {
  draft
  published
  archived
}
Enum lesson_progress_status {
  not_started
  in_progress
  completed
}

// ─── FOYDALANUVCHILAR ────────────────────────────────────────
//✅
Table users {
  id                uuid   [pk, default: `gen_random_uuid()`]
  username          varchar [unique, not null]
  password          varchar [not null]
  first_name        varchar
  last_name         varchar
  phone_number      varchar
  email             varchar [unique]
  telegram_id       bigint  [unique]
  telegram_username varchar
  avatar_url        varchar
  role              role    [not null, default: 'student']
  created_by        uuid    [ref: > users.id, note: 'Teacher yoki Admin yaratgan']
  refresh_token     text
  created_at        timestamptz [default: `now()`]
  updated_at        timestamptz [default: `now()`]

  indexes {
    username [unique]
    email    [unique]
    telegram_id [unique]
    role
  }
}
//✅
Table student_profiles {
  id            uuid    [pk, default: `gen_random_uuid()`]
  user_id       uuid    [unique, ref: > users.id]
  birth_date    date
  address       text
  cefr_level    cefr_level [note: 'Umumiy CEFR daraja']
  learning_goal varchar
  // ↓ user_skills'dan birlashtirildi — umumiy skill ballari (0–100)
  grammar_score          int [not null, default: 0]
  reading_score          int [not null, default: 0]
  listening_score        int [not null, default: 0]
  speaking_score         int [not null, default: 0]
  writing_score          int [not null, default: 0]
  vocabulary_score       int [not null, default: 0]
  vocabulary_words_count int [not null, default: 0, note: 'O‘zlashtirilgan so‘zlar soni']

  indexes {
    user_id [unique]
  }
}
//✅
Table teacher_profiles {
  id               uuid [pk, default: `gen_random_uuid()`]
  user_id          uuid [unique, ref: > users.id]
  bio              text
  specialization   varchar
  experience_years int

  indexes {
    user_id [unique]
  }
}

// ─── KURS TUZILISHI ──────────────────────────────────────────
//✅
Table units {
  id          uuid   [pk, default: `gen_random_uuid()`]
  number      int    [not null, note: '1–6']
  title       varchar [not null]
  description text
  status      lesson_status [not null, default: 'draft']
  created_at  timestamptz [default: `now()`]
  updated_at  timestamptz [default: `now()`]

  indexes {
    number [unique]
  }
}
//✅
Table lessons {
  id              uuid    [pk, default: `gen_random_uuid()`]
  unit_id         uuid    [ref: > units.id]
  lesson_number   varchar [note: '"3.09", "3.10" kabi']
  lesson_name     varchar [not null]
  order_index     int     [not null, default: 0, note: 'Unit ichidagi tartib']
  status          lesson_status [not null, default: 'draft']
  created_at      timestamptz [default: `now()`]
  updated_at      timestamptz [default: `now()`]

  indexes {
    unit_id
    (unit_id, order_index)
    status
  }
}

// ─── GRAMMATIKA ───────────────────────────────────────────────
//✅
Table grammar_contents {
  id            uuid    [pk, default: `gen_random_uuid()`]
  lesson_id     uuid    [ref: > lessons.id, note: 'ON DELETE CASCADE']
  component_key varchar [note: 'Frontend grammatika komponenti kaliti (masalan "lesson1") — DB kontenti bo‘lmasa']
  title         varchar [note: 'Grammatika mavzusi sarlavhasi']
  content       jsonb   [note: 'DB-driven kontent: qoidalar, formulalar, misollar (ixtiyoriy)']
  order_index   int     [not null, default: 0]
  created_at    timestamptz [default: `now()`]
  updated_at    timestamptz [default: `now()`]

  indexes { lesson_id }
}

// ─── READING ─────────────────────────────────────────────────
//✅
Table reading_contents {
  id                   uuid   [pk, default: `gen_random_uuid()`]
  lesson_id            uuid   [ref: > lessons.id]
  title                varchar [not null]
  text_content         text   [not null]
  word_count           int
  reading_time_minutes int
  order_index          int    [default: 0]
  created_at           timestamptz [default: `now()`]
  updated_at           timestamptz [default: `now()`]

  indexes { lesson_id }
}   
//✅
Table reading_questions {
  id                  uuid   [pk, default: `gen_random_uuid()`]
  reading_id          uuid   [ref: > reading_contents.id]
  question_text       text   [not null]
  question_type       question_type [not null]
  correct_explanation text
  order_index         int    [default: 0]

  indexes { reading_id }
}
//✅
Table reading_options {
  id            uuid    [pk, default: `gen_random_uuid()`]
  question_id   uuid    [ref: > reading_questions.id]
  option_text   text    [not null]
  is_correct    boolean [not null, default: false]
  order_index   int     [default: 0]

  indexes { question_id }
}

// ─── LISTENING ────────────────────────────────────────────────
//✅
Table listening_contents {
  id               uuid   [pk, default: `gen_random_uuid()`]
  lesson_id        uuid   [ref: > lessons.id]
  title            varchar [not null]
  audio_url        varchar [not null, note: 'Listening audio (/uploads/audio/...)']
  image_url        varchar [note: 'Butun mashq uchun rasm (jadval, forma, sahna)']
  duration_seconds int
  order_index      int    [default: 0]
  created_at       timestamptz [default: `now()`]
  updated_at       timestamptz [default: `now()`]

  indexes { lesson_id }
}
//✅
Table listening_transcripts {
  id               uuid    [pk, default: `gen_random_uuid()`]
  listening_id     uuid    [ref: > listening_contents.id]
  speaker_name     varchar
  timestamp_sec    float
  text_content     text    [not null]
  order_index      int     [default: 0]

  indexes { listening_id }
}
//✅
Table listening_questions {
  id                  uuid   [pk, default: `gen_random_uuid()`]
  listening_id        uuid   [ref: > listening_contents.id]
  question_text       text   [not null]
  question_type       question_type [not null]
  correct_explanation text
  image_url           varchar [note: 'Savol rasmi: sahna, forma yoki jadval']
  match_targets       jsonb   [note: 'matching o\'ng tomoni: ["Jane","Anna","Pat"] (DBda migratsiyada jsonb)']
  order_index         int    [default: 0]

  indexes { listening_id }
}
//✅
Table listening_options {
  id            uuid    [pk, default: `gen_random_uuid()`]
  question_id   uuid    [ref: > listening_questions.id]
  option_text   text    [not null]
  is_correct    boolean [not null, default: false]
  image_url     varchar [note: 'Variant rasm bo\'lsa (Ex.1 tipidagi image_choice)']
  match_key     varchar [note: 'Matching uchun: bu variant nimaga mos keladi']
  order_index   int     [default: 0]

  indexes { question_id }
}

// ─── LUG'AT ──────────────────────────────────────────────────
//✅
Table vocabularys {
  id            uuid           [pk, default: `gen_random_uuid()`]
  word          varchar        [not null]
  lang          language       [not null, default: 'en']
  ipa           varchar        [note: 'Talaffuz: /ˈmem.ə.rə.bəl/']
  pos           part_of_speech
  lesson_id     uuid           [ref: > lessons.id, note: 'ON DELETE SET NULL — dars o‘chsa so‘z qoladi']
  voice_url     varchar        [note: 'Google TTS talaffuz audio (/uploads/audio/...)']
  image_url     varchar
  order_index   bigint         [not null, default: 0]
  created_at    timestamptz    [default: `now()`]
  updated_at    timestamptz    [default: `now()`]

  indexes {
    lesson_id
  }
}
//✅
Table vocabulary_relations {
  id             uuid        [pk, default: `gen_random_uuid()`]
  vocabulary_id  uuid        [not null, ref: > vocabularys.id, note: 'ON DELETE CASCADE']
  translation_id uuid        [not null, ref: > vocabularys.id, note: 'ON DELETE CASCADE']
  attempts       bigint      [not null, default: 0]
  wrong_attempts bigint      [not null, default: 0]
  difficulty     float       [not null, default: 0]
  created_at     timestamptz [default: `now()`]
  updated_at     timestamptz [default: `now()`]
  // ikki yo'nalishli juftlik — unique qo'yilmadi

  indexes {
    vocabulary_id
    translation_id
  }
}
//✅
Table vocabulary_sessions {
  id              uuid        [pk, default: `gen_random_uuid()`]
  user_id         uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  completed_count int         [not null, default: 0]
  time_spent_sec  int         [not null, default: 0]
  created_at      timestamptz [default: `now()`]
  updated_at      timestamptz [default: `now()`]

  indexes {
    (user_id, created_at)
  }
}
//✅
Table vocabulary_examples {
  id             uuid        [pk, default: `gen_random_uuid()`]
  pair_id        uuid        [not null, ref: > vocabulary_relations.id, note: 'ON DELETE CASCADE']
  english_text   text        [not null]
  uzbek_text     text
  highlight_word varchar
  order_index    int         [default: 0]
  created_at     timestamptz [default: `now()`]
  updated_at     timestamptz [default: `now()`]

  indexes { pair_id }
}
// synonyms + antonyms birlashtirildi (relation_type bilan)
Table vocabulary_word_relations {
  vocabulary_id uuid               [not null, ref: > vocabularys.id, note: 'ON DELETE CASCADE']
  related_id    uuid               [not null, ref: > vocabularys.id, note: 'ON DELETE CASCADE']
  relation_type word_relation_type [not null, note: 'synonym | antonym']

  indexes {
    (vocabulary_id, related_id, relation_type) [pk]
  }
}


// ─── QUIZ (GRAMMATIKA MUSTAHKAMLASH) ─────────────────────────

Table quiz_contents {
  id          uuid        [pk, default: `gen_random_uuid()`]
  lesson_id   uuid        [not null, ref: > lessons.id, note: 'ON DELETE CASCADE']
  title       varchar     [not null, default: 'Quiz']
  order_index int         [default: 0]
  created_at  timestamptz [default: `now()`]
  updated_at  timestamptz [default: `now()`]

  indexes { lesson_id }
}

Table quiz_exercises {
  id            uuid          [pk, default: `gen_random_uuid()`]
  quiz_id       uuid          [not null, ref: > quiz_contents.id, note: 'ON DELETE CASCADE']
  title         varchar       [note: 'Exercise 1, Exercise 2...']
  instructions  text          [note: 'Match "Personal pronouns" — kishilik olmoshlari']
  exercise_type exercise_type [not null]
  order_index   int           [default: 0]
  created_at    timestamptz   [default: `now()`]
  updated_at    timestamptz   [default: `now()`]

  indexes { quiz_id }
}

Table quiz_items {
  id             uuid        [pk, default: `gen_random_uuid()`]
  exercise_id    uuid        [not null, ref: > quiz_exercises.id, note: 'ON DELETE CASCADE']
  item_text      text        [not null, note: 'Sophie | Ali ____ a student']
  correct_answer varchar     [not null, note: 'she | is']
  options        jsonb       [note: 'Faqat multiple_choice uchun: ["am","is","are"]']
  order_index    int         [default: 0]
  created_at     timestamptz [default: `now()`]
  updated_at     timestamptz [default: `now()`]

  indexes { exercise_id }
}

Table quiz_student_answers {
  id           uuid        [pk, default: `gen_random_uuid()`]
  user_id      uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  item_id      uuid        [not null, ref: > quiz_items.id, note: 'ON DELETE CASCADE']
  quiz_id      uuid        [not null, ref: > quiz_contents.id, note: 'ON DELETE CASCADE']
  given_answer varchar     [not null, note: 'O‘quvchi bergan javob']
  is_correct   boolean     [not null, default: false]
  answered_at  timestamptz [default: `now()`]
  created_at   timestamptz [default: `now()`]
  updated_at   timestamptz [default: `now()`]

  indexes {
    (user_id, item_id) [unique]
    quiz_id
  }
}

// ─── TEST / AMALIYOT ─────────────────────────────────────────
// ⚠️ REJALASHTIRILGAN: bu 2 jadval hali kodda (entity) YO'Q — hozir quiz_* ishlatilmoqda.
//    Delete qoidalari taklif sifatida; kod yozilganda tasdiqlanadi.

Table test_questions {
  id                 uuid          [pk, default: `gen_random_uuid()`]
  lesson_id          uuid          [not null, ref: > lessons.id, note: 'ON DELETE CASCADE']
  question_text      text          [not null]
  question_type      question_type [not null]
  media_url          varchar        [note: 'Savol media fayli (/uploads/...)']
  time_limit_seconds int
  order_index        int           [default: 0]
  created_at         timestamptz   [default: `now()`]
  updated_at         timestamptz   [default: `now()`]

  indexes { lesson_id }
}

Table test_options {
  id          uuid        [pk, default: `gen_random_uuid()`]
  question_id uuid        [not null, ref: > test_questions.id, note: 'ON DELETE CASCADE']
  option_text text        [not null]
  is_correct  boolean     [not null, default: false]
  order_index int         [default: 0]
  created_at  timestamptz [default: `now()`]
  updated_at  timestamptz [default: `now()`]

  indexes { question_id }
}

// ─── PROGRESS ────────────────────────────────────────────────
//✅
Table lesson_progress {
  id               uuid   [pk, default: `gen_random_uuid()`]
  user_id          uuid   [ref: > users.id]
  lesson_id        uuid   [ref: > lessons.id]
  status           lesson_progress_status [not null, default: 'not_started']
  score            int    [note: 'Jami ball 0–100']
  grammar_score    int    [note: '0–100, null = bu darsda yo\'q']
  quiz_score       int    [note: '0–100, null = quiz bloki yo\'q']
  vocabulary_score int    [note: '0–100, null = bu darsda yo\'q']
  listening_score  int    [note: '0–100, null = bu darsda yo\'q']
  reading_score    int    [note: '0–100, null = bu darsda yo\'q']
  speaking_score   int    [note: '0–100, null = bu darsda yo\'q']
  time_spent_sec   int    [default: 0]
  attempts         int    [default: 1]
  completed_at     timestamptz
  created_at       timestamptz [default: `now()`]
  updated_at       timestamptz [default: `now()`]

  indexes {
    (user_id, lesson_id) [unique]
    user_id
    lesson_id
    status
  }
}

Table user_vocabulary_progress {
  id             uuid         [pk, default: `gen_random_uuid()`]
  user_id        uuid         [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  pair_id        uuid         [not null, ref: > vocabulary_relations.id, note: 'ON DELETE CASCADE']
  status         vocab_status [not null, default: 'new']
  attempts       int          [not null, default: 0]
  wrong_attempts int          [not null, default: 0]
  next_review_at timestamptz  [note: 'SRS: keyingi takror vaqti']
  created_at     timestamptz  [default: `now()`]
  updated_at     timestamptz  [default: `now()`]

  indexes {
    (user_id, pair_id) [unique]
    next_review_at
    status
  }
}

// ⚠️ KOD-SYNC KERAK: entity hozir session_id + smallint mode + vaqtsiz.
//    Bu maqsad holat: user_id + enum mode + answered_at + timestamp (entity qayta yoziladi).
Table vocabulary_practice_logs {
  id          uuid          [pk, default: `gen_random_uuid()`]
  user_id     uuid          [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  pair_id     uuid          [not null, ref: > vocabulary_relations.id, note: 'ON DELETE CASCADE']
  mode        practice_mode [not null]
  correct     boolean       [not null]
  answered_at timestamptz   [default: `now()`]
  created_at  timestamptz   [default: `now()`]
  updated_at  timestamptz   [default: `now()`]

  indexes {
    (user_id, answered_at)
    (user_id, pair_id)
  }
}

// user_skills OLIB TASHLANDI — ballar student_profiles'ga ustun sifatida ko'chirildi.


// ─── GURUHLAR ────────────────────────────────────────────────

Table groups {
  id                    uuid         [pk, default: `gen_random_uuid()`]
  name                  varchar      [not null]
  description           text
  color                 varchar      [note: 'UI rang: blue|emerald|amber|zinc']
  teacher_id            uuid         [ref: > users.id, note: 'ON DELETE SET NULL']
  created_by            uuid         [not null, ref: > users.id, note: 'Kodda hozir FK bog‘lanish yo‘q — faqat ustun']
  status                group_status [not null, default: 'active']
  auto_advance_enabled  boolean      [not null, default: true, note: 'Gating: keyingi darsga avtomatik o‘tish']
  manual_lesson_ceiling int          [note: 'Gating: qo‘lda yuqori chegara (null = cheksiz)']
  created_at            timestamptz  [default: `now()`]
  updated_at            timestamptz  [default: `now()`]

  indexes {
    teacher_id
    status
  }
}

Table group_members {
  group_id  uuid        [ref: > groups.id, note: 'ON DELETE CASCADE']
  user_id   uuid        [ref: > users.id, note: 'ON DELETE CASCADE']
  joined_at timestamptz [default: `now()`, note: 'Maqsad holat — kodda M2M ni join-entity ga aylantirish kerak']

  indexes {
    (group_id, user_id) [pk]
    user_id
  }
}

// group_member_settings — kodda BOR edi, DBMLga qo'shildi (gating: bepul / qo'lda chegara)
Table group_member_settings {
  id                    uuid        [pk, default: `gen_random_uuid()`]
  group_id              uuid        [not null, ref: > groups.id, note: 'ON DELETE CASCADE']
  user_id               uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  is_free               boolean     [not null, default: false, note: 'Bu a‘zoga chegarasiz (bepul) kirish']
  manual_unlock_ceiling int         [note: 'Shu a‘zo uchun qo‘lda ochilgan chegara']
  created_at            timestamptz [default: `now()`]
  updated_at            timestamptz [default: `now()`]

  indexes {
    (group_id, user_id) [unique]
  }
}

// group_lessons OLIB TASHLANDI — gating manual_lesson_ceiling + group_member_settings bilan ishlaydi.

// ─── JADVAL ──────────────────────────────────────────────────

Table schedules {
  id               uuid        [pk, default: `gen_random_uuid()`]
  group_id         uuid        [not null, ref: > groups.id, note: 'ON DELETE CASCADE']
  teacher_id       uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  topic            varchar
  days_of_week     jsonb       [not null, note: 'Massiv: [0,2,4] — Du,Ch,Ju (kodda hozir varchar → jsonb sync kerak)']
  start_time       time        [not null]
  duration_minutes int         [not null, default: 90]
  is_recurring     boolean     [not null, default: true]
  valid_from       date        [not null]
  valid_until      date
  created_at       timestamptz [default: `now()`]
  updated_at       timestamptz [default: `now()`]

  indexes {
    group_id
    teacher_id
  }
}

Table schedule_sessions {
  id               uuid           [pk, default: `gen_random_uuid()`]
  schedule_id      uuid           [not null, ref: > schedules.id, note: 'ON DELETE CASCADE']
  group_id         uuid           [not null, ref: > groups.id, note: 'ON DELETE CASCADE']
  teacher_id       uuid           [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  session_date     date           [not null]
  start_time       time           [not null]
  duration_minutes int            [not null, default: 90]
  topic            varchar
  status           session_status [not null, default: 'scheduled']
  notes            text
  created_at       timestamptz    [default: `now()`]
  updated_at       timestamptz    [default: `now()`]

  indexes {
    schedule_id
    (group_id, session_date)
  }
}

Table attendance {
  id         uuid              [pk, default: `gen_random_uuid()`]
  session_id uuid              [not null, ref: > schedule_sessions.id, note: 'ON DELETE CASCADE']
  user_id    uuid              [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  status     attendance_status [not null]
  joined_at  timestamptz
  created_at timestamptz       [default: `now()`]
  updated_at timestamptz       [default: `now()`]

  indexes {
    (session_id, user_id) [unique]
    user_id
  }
}

// ─── GAMIFIKATSIYA ───────────────────────────────────────────

Table user_gamification {
  id                 uuid        [pk, default: `gen_random_uuid()`]
  user_id            uuid        [not null, unique, ref: > users.id, note: 'ON DELETE CASCADE']
  level              int         [not null, default: 1]
  xp_total           int         [not null, default: 0]
  xp_weekly          int         [not null, default: 0]
  league             league      [not null, default: 'bronze']
  streak_current     int         [not null, default: 0]
  streak_max         int         [not null, default: 0]
  last_activity_date date
  rank_weekly        int
  created_at         timestamptz [default: `now()`]
  updated_at         timestamptz [default: `now()`]

  indexes {
    user_id [unique]
    xp_total
    xp_weekly
    league
  }
}

// xp_transactions OLIB TASHLANDI — XP endi activity_events.xp_earned + xp_source ustunlarida.

Table achievements {
  id              uuid                  [pk, default: `gen_random_uuid()`]
  code            varchar               [unique, not null]
  title           varchar               [not null]
  description     text
  icon            varchar
  xp_reward       int                   [not null, default: 0]
  condition_type  achievement_condition [not null]
  condition_value int                   [not null]
  created_at      timestamptz           [default: `now()`]
  updated_at      timestamptz           [default: `now()`]

  indexes {
    code [unique]
  }
}

Table user_achievements {
  id             uuid        [pk, default: `gen_random_uuid()`]
  user_id        uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  achievement_id uuid        [not null, ref: > achievements.id, note: 'ON DELETE CASCADE']
  earned_at      timestamptz [default: `now()`]
  created_at     timestamptz [default: `now()`]
  updated_at     timestamptz [default: `now()`]

  indexes {
    (user_id, achievement_id) [unique]
    user_id
  }
}

// ─── KUNLIK KUZATUV ──────────────────────────────────────────

Table daily_tracking {
  id                  uuid        [pk, default: `gen_random_uuid()`]
  user_id             uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  date                date        [not null]
  minutes_spent       int         [not null, default: 0]
  lessons_completed   int         [not null, default: 0]
  vocabulary_reviewed int         [not null, default: 0]
  listening_done      boolean     [not null, default: false]
  goal_minutes        int         [not null, default: 30]
  created_at          timestamptz [default: `now()`]
  updated_at          timestamptz [default: `now()`]

  indexes {
    (user_id, date) [unique]
  }
}

// activity_log + xp_transactions birlashtirildi → umumiy faoliyat oqimi.
// day_of_week/hour_of_day olib tashlandi (occurred_at'dan hisoblanadi).
Table activity_events {
  id            uuid          [pk, default: `gen_random_uuid()`]
  user_id       uuid          [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  activity_type activity_type [note: 'Bajarilgan faoliyat (sof XP bonus bo‘lsa null)']
  occurred_at   timestamptz   [not null, default: `now()`]
  duration_sec  int           [not null, default: 0]
  xp_earned     int           [not null, default: 0, note: 'Shu hodisada berilgan XP']
  xp_source     xp_source     [note: 'XP sababi (xp_earned>0 bo‘lganda)']
  reference_id  uuid          [note: 'Polimorf: lesson_id / vocabulary_id (FK yo‘q)']
  meta          jsonb         [note: 'Qo‘shimcha kontekst']
  created_at    timestamptz   [default: `now()`]
  updated_at    timestamptz   [default: `now()`]

  indexes {
    (user_id, occurred_at)
    activity_type
    xp_source
  }
}

// ─── TOPSHIRIQLAR ────────────────────────────────────────────

Table assignments {
  id          uuid              [pk, default: `gen_random_uuid()`]
  title       varchar           [not null]
  description text
  type        assignment_type   [not null]
  teacher_id  uuid              [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  group_id    uuid              [ref: > groups.id, note: 'ON DELETE SET NULL']
  lesson_id   uuid              [ref: > lessons.id, note: 'ON DELETE SET NULL']
  due_date    timestamptz
  max_score   int               [not null, default: 100]
  status      assignment_status [not null, default: 'draft']
  created_at  timestamptz       [default: `now()`]
  updated_at  timestamptz       [default: `now()`]

  indexes {
    teacher_id
    (group_id, status)
    due_date
  }
}

Table assignment_submissions {
  id            uuid              [pk, default: `gen_random_uuid()`]
  assignment_id uuid              [not null, ref: > assignments.id, note: 'ON DELETE CASCADE']
  student_id    uuid              [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  file_url      varchar
  text_content  text
  score         int
  feedback      text
  status        submission_status [not null, default: 'pending']
  submitted_at  timestamptz
  graded_at     timestamptz
  graded_by     uuid              [ref: > users.id, note: 'ON DELETE SET NULL']
  created_at    timestamptz       [default: `now()`]
  updated_at    timestamptz       [default: `now()`]

  indexes {
    (assignment_id, student_id) [unique]
    student_id
    status
    graded_by
  }
}

// ─── BILDIRISHNOMALAR ────────────────────────────────────────

Table notifications {
  id             uuid              [pk, default: `gen_random_uuid()`]
  user_id        uuid              [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  type           notification_type [not null]
  title          varchar           [not null]
  body           text
  is_read        boolean           [not null, default: false]
  reference_id   uuid              [note: 'Polimorf havola ID (FK yo‘q)']
  reference_type varchar           [note: 'lesson|assignment|achievement|message']
  created_at     timestamptz       [default: `now()`]
  updated_at     timestamptz       [default: `now()`]

  indexes {
    (user_id, is_read)
    created_at
  }
}

// ─── XABARLAR ────────────────────────────────────────────────

Table messages {
  id          uuid        [pk, default: `gen_random_uuid()`]
  sender_id   uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  receiver_id uuid        [not null, ref: > users.id, note: 'ON DELETE CASCADE']
  body        text        [not null]
  attachments jsonb       [note: '[{file_id, type, name}] (kodda hozir text → jsonb sync kerak)']
  is_read     boolean     [not null, default: false]
  created_at  timestamptz [default: `now()`]
  updated_at  timestamptz [default: `now()`]

  indexes {
    sender_id
    (receiver_id, is_read)
    created_at
  }
}

// ============================================================
// TUGADI — 46 jadval + 22 enum.
// Delete qoidalari `note: 'ON DELETE ...'` sifatida (dbdiagram parseri
// inline `delete:` ni qo'llab-quvvatlamaydi; enumlar ko'p-qatorli bo'lishi shart).
// Kod ↔ DBML moslashtirish ro'yxati: SQL/CODE_SYNC.md
// ============================================================